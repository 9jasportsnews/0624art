# 站點與語系
SITE_ID=jitabet
SITE_LOCALE=en
HOME_URL=https://www.jitabet.cloud/?version=6.46.6-fc

# 測試帳號（驗證碼由 OCR 自動辨識；除錯可手動指定 4 碼）
TEST_USERNAME=Testing04
TEST_PASSWORD=jt44444
# TEST_CAPTCHA=1234
# MANUAL_CAPTCHA=1  # 搭配 --headed，手動輸入驗證碼（每個已登入 test 都會重新登入）
# SKIP_GLOBAL_MEMBER_LOGIN=1  # 跳過測試開始前的全域登入（已登入測項改各自 OCR）

# Telegram 通知（notify-telegram.mjs）
# TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=369767308
# TELEGRAM_NOTIFY_ON=always  # always=通過與失敗都推送；fail=僅失敗推送
# TELEGRAM_AUTO_NOTIFY=1    # 設 0 關閉測試結束自動推送
# Telegram 標題會標示執行環境：本機 或 GitHub Actions · 定時全項檢測

# GitHub Actions：Settings → Secrets → New secret
#   Name: ENV_1 或 ENV 或 E2E_ENV
#   Secret: 整段貼上（含下面 HOME_URL～TELEGRAM_CHAT_ID，一行一個）

# 本機每日定時（Mac 需開機）：npm run schedule:install
# 預設每天 10:30；自訂：npm run schedule:install -- 9 0
# 取消：npm run schedule:uninstall
