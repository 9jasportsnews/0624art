{
  "name": "check-web-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "playwright install chromium",
    "postinstall": "node scripts/postinstall-playwright.mjs",
    "test": "playwright test",
    "test:recorded": "node scripts/run-recorded-suite.mjs",
    "test:smoke": "playwright test tests/recorded/desktop-download.spec.ts -g \"電腦版-進入首頁\" --project=desktop-chrome",
    "schedule:once": "node scripts/schedule-local-wait.mjs",
    "schedule:install": "node scripts/install-local-schedule.mjs",
    "schedule:uninstall": "node scripts/uninstall-local-schedule.mjs",
    "test:fixture": "playwright test tests/video-html tests/helpers/youtube-embed.visual.spec.ts",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "report:save": "node scripts/save-blob-run.mjs",
    "report:merge": "node scripts/merge-blob-reports.mjs",
    "report:merge-export": "REPORT_EXPORT=1 node scripts/merge-blob-reports.mjs",
    "report:export": "node scripts/export-test-summary.mjs",
    "report:export-pdf": "node scripts/export-test-summary-pdf.mjs",
    "notify:telegram": "node scripts/notify-telegram.mjs",
    "notify:ping": "node scripts/notify-ping.mjs",
    "notify:verify": "node scripts/verify-telegram-env.mjs",
    "notify:report": "node scripts/notify-show-report.mjs",
    "notify:video-playback": "node scripts/notify-video-playback.mjs",
    "notify:video-playback:only": "node scripts/notify-video-playback.mjs --skip-run",
    "notify:playlist": "node scripts/notify-playlist-video.mjs",
    "notify:playlist:only": "node scripts/notify-playlist-video.mjs --skip-run",
    "codegen": "playwright codegen",
    "dashboard": "node dashboard/server.js",
    "sync:cases": "node scripts/sync-test-cases.mjs",
    "build:netlify": "node scripts/generate-report-json.mjs",
    "serve": "PORT=5500 node dashboard/server.js",
    "serve:report": "python3 -m http.server 5500 --directory playwright-report",
    "serve:public": "python3 -m http.server 5500 --directory dashboard/public",
    "serve:static": "python3 -m http.server 5500 --directory dashboard/public",
    "serve:root": "python3 -m http.server 5500"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.0",
    "dotenv": "^16.5.0",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
